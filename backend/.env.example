# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: openai | gemini | ollama
LLM_PROVIDER=openai

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite-preview
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# ── Ollama (optional) ────────────────────────────────────────────────────────
# Install from https://ollama.com/ and run: ollama pull qwen3.5:9b
OLLAMA_MODEL=qwen3.5:9b
OLLAMA_BASE_URL=http://localhost:11434

# ── Pinecone vector store ────────────────────────────────────────────────────
# Get your key at https://www.pinecone.io/
# The index is created automatically on startup. Its dimension is fixed at
# creation and must match the embedding model: openai=1536, gemini/ollama=768.
# Switching LLM_PROVIDER across that boundary requires a new index name.
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=nova-pinecone-index
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# ── Google OAuth (Calendar integration) ──────────────────────────────────────
# Create an OAuth client at https://console.cloud.google.com/ (type: Web app)
# and add the redirect URI below to its authorized redirect URIs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8010/integrations/google/callback

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate a random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── LangSmith observability (optional) ───────────────────────────────────────
# Get your key at https://smith.langchain.com/
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=Nova
LANGSMITH_TRACING=false

# ── Storage paths (defaults work out of the box) ─────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./nova.db
PDF_UPLOAD_DIR=./pdf_uploads
KNOWLEDGE_BASE_DIR=./knowledge_base
USER_MEMORY_DIR=./user_memory

# ── RAG config ────────────────────────────────────────────────────────────────
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
